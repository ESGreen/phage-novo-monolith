# The Phage website configuration
#
# Copy this file to:
#
#   /etc/thephage/thephage.toml
#
# The real file should not be committed to git.
#
# Recommended permissions:
#
#   owner: root:phage
#   mode:  0640
#
# This file contains secrets such as database passwords and Stripe keys.
# Keep it readable only by root and the account that runs the website.
#
# After editing this file, restart the web application service.
#
# Example:
#
#   sudo systemctl restart thephage
#
# This example file contains dummy values. Replace every CHANGE_ME value.


[site]

# Public base URL for the website.
#
# Do not include a trailing slash.
#
# Production:
#   https://thephage.org
#
base_url = "https://thephage.org"


# Django secret key.
#
# This must be a long random value.
# Do not reuse this value across different deployments.
#
secret_key = "CHANGE_ME_long_random_secret_key"


# Debug mode.
#
# Production must be false.
# Local development may use true.
#
debug = false


# Hostnames this site is allowed to serve.
#
# Include every hostname that should reach this Django app.
#
allowed_hosts = [
  "thephage.org",
  "www.thephage.org",
]


# Timezone used for admin-entered dates and tax timestamps.
#
# Keep this as America/Los_Angeles unless the camp explicitly changes
# how tax deadlines are defined.
#
timezone = "America/Los_Angeles"


[database]

# PostgreSQL database used by the website.
#
# V1 expects PostgreSQL. Do not use SQLite or MySQL in production.


# Database server hostname.
#
# If PostgreSQL runs on the same EC2 instance as the website, use:
#
#   "localhost"
#
host = "localhost"


# Database server port.
#
# PostgreSQL default is 5432.
#
port = 5432


# Database name.
#
name = "thephage"


# Database user.
#
user = "thephage"


# Database password.
#
# This value is secret.
#
password = "CHANGE_ME_database_password"


[paths]

# Filesystem paths used by the deployed website.
#
# These are local paths on the server, not URLs.


# Static public HTML site.
#
# This is the hand-written/offline public website, not Django app assets.
#
# This directory is served at:
#
#   /public/
#
# Example:
#
#   /var/www/thephage/public/index.html
#
# Public pages, public images, and other public-only files may live here.
#
public_root = "/var/www/thephage/public"


# Django static assets.
#
# This is for Django/app/admin CSS, JavaScript, fonts, and similar assets.
# It is not where public HTML pages go.
# It is not where uploaded user/admin media goes.
#
# Django's collectstatic command writes here during deployment.
#
# This directory is served at:
#
#   /static/
#
static_root = "/var/www/thephage/static"


# Uploaded media files.
#
# This is for files uploaded through the website, such as profile pictures
# and images uploaded through the media admin.
#
# It is not where hand-written public HTML pages go.
# It is not where Django/app CSS or JavaScript goes.
#
# This directory is served at:
#
#   /media/
#
# V1 uses one flat media folder with no subdirectories.
#
media_root = "/var/www/thephage/media"


# Local temporary directory used by the app for short-lived files.
#
# This should be writable by the web app user.
#
tmp_root = "/var/tmp/thephage"


[stripe]

# Stripe credentials used by the payment system.
#
# The active Stripe mode is controlled in the website admin:
#
#   /admin/stripe/
#
# Do not edit this file just to switch between test mode and live mode.
# Admins should use /admin/stripe/ for that.
#
# This file only provides the credentials needed for both modes.


# Stripe test secret key.
#
# Used when /admin/stripe/ is set to test mode.
# Usually starts with:
#
#   sk_test_
#
test_secret_key = "CHANGE_ME_sk_test_..."


# Stripe test publishable key.
#
# Used by Stripe Checkout when the site is in test mode.
# Usually starts with:
#
#   pk_test_
#
# This is not as sensitive as the secret key, but still keep it here
# with the rest of the Stripe configuration.
#
test_publishable_key = "CHANGE_ME_pk_test_..."


# Stripe test webhook signing secret.
#
# Used to verify webhook messages from Stripe test mode.
# Usually starts with:
#
#   whsec_
#
test_webhook_secret = "CHANGE_ME_whsec_..."


# Stripe live secret key.
#
# Used when /admin/stripe/ is set to live mode.
# Usually starts with:
#
#   sk_live_
#
# This key can create real payments. Treat it as highly sensitive.
#
live_secret_key = "CHANGE_ME_sk_live_..."


# Stripe live publishable key.
#
# Used by Stripe Checkout when the site is in live mode.
# Usually starts with:
#
#   pk_live_
#
live_publishable_key = "CHANGE_ME_pk_live_..."


# Stripe live webhook signing secret.
#
# Used to verify webhook messages from Stripe live mode.
# Usually starts with:
#
#   whsec_
#
live_webhook_secret = "CHANGE_ME_whsec_..."


[backups]

# Backup settings for lightweight backups.
#
# Full EC2 images are still the preferred backup before major system changes.
# This section is for smaller recurring backups while the site is live.


# Enable or disable PostgreSQL database backups.
#
# Production should normally keep this true.
#
database_backups_enabled = true


# Enable or disable deployment configuration backups.
#
# This backs up selected server configuration files and deployment scripts.
# It should not replace full EC2 images.
#
config_backups_enabled = true


# Enable or disable uploaded media backups.
#
# Media includes uploaded profile pictures and uploaded page images.
#
media_backups_enabled = true


# S3 bucket used for backups.
#
# The bucket should be private and encrypted.
#
s3_bucket = "web2-backups-thephage"


# Prefix inside the S3 bucket.
#
# Example final paths might look like:
#
#   s3://web2-backups-thephage/prod/database/2026-07-03-0100.dump
#   s3://web2-backups-thephage/prod/config/2026-07-03-0100.tar.gz
#
s3_prefix = "prod"


# Local directory used while preparing backup files before upload.
#
# This directory should be writable by the backup process.
#
local_backup_dir = "/var/backups/thephage"


# Number of days to keep database backups.
#
# V1 runs daily database backups. Keeping 30 days is a reasonable
# starting point.
#
database_retention_days = 30


# Number of days to keep config backups.
#
config_retention_days = 90


# Number of days to keep non-current media object versions.
#
# Media backups are incremental S3 syncs, not repeated full media tarballs.
# S3 bucket versioning and lifecycle rules provide the recovery window for
# accidental deletes or overwrites.
#
media_retention_days = 45


# Paths to include in deployment configuration backups.
#
# These should be files/directories needed to understand or recreate
# the deployed server configuration.
#
# Do not include large media directories here.
#
config_paths = [
  "/etc/thephage/thephage.toml",
  "/etc/nginx/sites-available/thephage",
  "/etc/systemd/system/thephage.service",
  "/etc/systemd/system/thephage-backup.service",
  "/etc/systemd/system/thephage-backup.timer",
]
